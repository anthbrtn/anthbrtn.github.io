---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact - Anthony Burton';
---

<BaseLayout title={title}>
  <header class="mb-8">
    <h1 class="text-3xl font-bold page-title text-purple-800">Contact</h1>
  </header>

  <section class="content-section bg-gradient-to-r from-purple-5 to-indigo-5 p-6 rounded-lg">
    <div class="flex flex-col md:flex-row gap-8">
      <div class="md:w-1/3 flex justify-center items-start">
        <div class="bg-gray-200 border-2 border-dashed rounded-xl w-48 h-48 flex items-center justify-center text-gray-500">
          Photo
        </div>
      </div>
      <div class="md:w-2/3 prose prose-lg max-w-none">
        <p class="text-gray-700">I can be reached at ab [at] anthbrtn [dot] com.</p>
        
        <h2 class="text-2xl font-semibold mt-6 mb-4 text-purple-700">Social Media & Academic Profiles</h2>
        <ul class="space-y-2">
          <li><a href="https://twitter.com/anthbrtn" class="accent-text hover:underline">Twitter: @anthbrtn</a></li>
          <li><a href="https://gitlab.com/anthbrtn" class="accent-text hover:underline">GitLab: anthbrtn</a></li>
          <li><a href="https://scholar.google.com/citations?user=FxoLSjYAAAAJ&hl=en&inst=10441630620217902552" class="accent-text hover:underline">Google Scholar</a></li>
        </ul>
      </div>
    </div>
  </section>

  <hr class="my-8 border-purple-200" />

  <nav class="flex flex-wrap justify-center gap-4 mt-8">
    <a href="/" class="nav-link">← Home</a>
    <a href="/about" class="nav-link">About</a>
    <a href="/presentations" class="nav-link">Presentations</a>
    <a href="/publications" class="nav-link">Publications</a>
    <a href="/cv" class="nav-link">CV</a>
  </nav>
  
  <hr class="my-8 border-purple-200" />
  
  <div class="text-center text-sm text-gray-500 mt-12">
    <p>© {new Date().getFullYear()} Anthony Burton</p>
  </div>
</BaseLayout>