---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Curriculum Vitae - Anthony Burton';
---

<BaseLayout title={title}>
  <header class="mb-8">
    <h1 class="text-3xl font-bold page-title text-purple-800">Curriculum Vitae</h1>
  </header>

  <section class="content-section bg-gradient-to-r from-purple-5 to-indigo-5 p-6 rounded-lg">
    <div class="prose prose-lg max-w-none">
      <div class="flex flex-col items-center">
        <div class="bg-gray-200 border-2 border-dashed rounded-xl w-48 h-48 flex items-center justify-center text-gray-500 mb-6">
          Photo
        </div>
        <div class="minimal-border w-full overflow-hidden mt-4">
          <embed src="/assets/pdfs/burton_cv.pdf" type="application/pdf" width="100%" height="800px" class="block w-full rounded" />
        </div>
      </div>
    </div>
  </section>

  <hr class="my-8 border-purple-200" />

  <nav class="flex flex-wrap justify-center gap-4 mt-8">
    <a href="/" class="nav-link">← Home</a>
    <a href="/about" class="nav-link">About</a>
    <a href="/presentations" class="nav-link">Presentations</a>
    <a href="/publications" class="nav-link">Publications</a>
    <a href="/contact" class="nav-link">Contact</a>
  </nav>
  
  <hr class="my-8 border-purple-200" />
  
  <div class="text-center text-sm text-gray-500 mt-12">
    <p>© {new Date().getFullYear()} Anthony Burton</p>
  </div>
</BaseLayout>